<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_Contract_Start_Date</name>
        <label>Update Contract Start Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.StartDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.CompanySignedDate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_Account_Record_Type</targetReference>
        </connector>
    </assignments>
    <assignments>
