        <dataType>String</dataType>
        <value>
            <stringValue>Generate PRO Form without PII</stringValue>
        </value>
    </choices>
    <choices>
        <name>generateProFormWithPII</name>
        <choiceText>Generate PRO Form with PII</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Generate PRO Form with PII</stringValue>
        </value>
    </choices>
