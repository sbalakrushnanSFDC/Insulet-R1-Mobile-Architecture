        <value>
            <stringValue>{&quot;location&quot;:&quot;top&quot;,&quot;type&quot;:&quot;simple&quot;}</stringValue>
        </value>
    </customProperties>
    <description>Use to generate PRO form with and without PHI information.</description>
    <environments>Default</environments>
    <formulas>
        <name>evaluateFormTypeSelection</name>
        <dataType>String</dataType>
        <expression>CASE(
   {!generateProFormButtons},
  &quot;Generate PRO Form with PII&quot;, &quot;Generate PRO Form with PII&quot;,
  &quot;Generate PRO Form without PII&quot;, &quot;Generate PRO Form without PII&quot;,
  &quot;&quot;
)</expression>
    </formulas>
    <formulas>
        <description>Stores partner server URL.</description>
        <name>partnerServerURL_520</name>
        <dataType>String</dataType>
        <expression>{!$Api.Partner_Server_URL_520}</expression>
    </formulas>
    <interviewLabel>Generate PRO Form {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Generate PRO Form</label>
    <processMetadataValues>
        <name>BuilderType</name>
