            </conditions>
            <label>Bypassed</label>
        </rules>
    </decisions>
    <decisions>
        <description>To Evaluate if its a new Record or a record updated to be IsPrimary</description>
        <name>Is_New_or_isPrimary_set_to_True</name>
        <label>Is New or isPrimary set to True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Check_if_the_Contact_has_Account_Associated</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>New</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Label.Practice_Account_Record_Type_Developer_Name</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Account.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Label.Patient_Record_Type_Label</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_IsPrimary</targetReference>
            </connector>
            <label>New</label>
        </rules>
        <rules>
            <name>Updated_to_IsPrimary</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Is_Primary__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Is_Primary__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Label.Practice_Account_Record_Type_Developer_Name</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Account.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Label.Patient_Record_Type_Label</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>On_Existing_ACR_set_isPrimary_to_False</targetReference>
            </connector>
            <label>Updated to IsPrimary</label>
        </rules>
    </decisions>
