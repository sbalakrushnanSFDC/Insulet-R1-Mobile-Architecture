<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Formatted_Date_of_Birth__c</fullName>
    <description>Displays the Date of Birth field in MM/DD/YYYY format.</description>
    <externalId>false</externalId>
    <formula>IF(
    ISBLANK( Account__r.Date_of_Birth__c ),
    &quot;&quot;,
    LPAD(TEXT(MONTH(Account__r.Date_of_Birth__c)), 2, &quot;0&quot;) &amp; &quot;/&quot; &amp;
    LPAD(TEXT(DAY(Account__r.Date_of_Birth__c)), 2, &quot;0&quot;) &amp; &quot;/&quot; &amp;
    TEXT(YEAR(Account__r.Date_of_Birth__c))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Formatted Date of Birth</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
