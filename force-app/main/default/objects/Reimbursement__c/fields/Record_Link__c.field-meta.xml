<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Record_Link__c</fullName>
    <description>Stores a clickable link that directs users to the Reimbursement record for quick access and reference.</description>
    <externalId>false</externalId>
    <formula>&quot;https://&quot; +
MID($Api.Partner_Server_URL_600,
FIND(&quot;://&quot;, $Api.Partner_Server_URL_600) + 3,
FIND(&quot;.my.salesforce.com&quot;, $Api.Partner_Server_URL_600) - FIND(&quot;://&quot;, $Api.Partner_Server_URL_600) - 3
) +
&quot;.my.site.com/TrainerPortal/reimbursement/&quot;&amp;Id</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Record Link</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
