<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Trigger_Event__c</fullName>
    <description>Specifies which trigger event should evaluate this rule. Used to filter rules and reduce evaluation overhead.</description>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>Select &apos;INSERT&apos; for rules that should only fire on record insert, &apos;UPDATE&apos; for rules that fire on record update. Leave blank to fire on both events. Filtering reduces the number of rules evaluated for better performance.</inlineHelpText>
    <label>Trigger Event</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>INSERT</fullName>
                <default>true</default>
                <label>INSERT</label>
            </value>
            <value>
                <fullName>UPDATE</fullName>
                <default>false</default>
                <label>UPDATE</label>
            </value>
            <value>
                <fullName>Create</fullName>
                <default>false</default>
                <isActive>false</isActive>
                <label>Create</label>
            </value>
            <value>
                <fullName>Status Change</fullName>
                <default>false</default>
                <isActive>false</isActive>
                <label>Status Change</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
