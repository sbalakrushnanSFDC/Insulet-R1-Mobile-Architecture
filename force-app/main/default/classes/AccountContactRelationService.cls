/**
 * @description Class responsible for creating AccountContactRelation records during Lead conversion
 * when Practice__c or Provider_Practice_Affiliation__c on Lead is populated. Avoids duplicates and logs partial DML failures.
 * US NGOMCT-343
 * @author Shailja Jain
 * @date 2025-10-06
 * 
 * NOTE -System Mode  : DML and SOQL operations are executed for non-admin users who do not have access to Sobject fields. 
 *                      To allow these operations for non-admin users, they must be executed in system context.
 * 
 * Version      Modified Date       Modified By                   Brief Note
 * V1.0.0       2025-10-06       	  Shailja Jain                  Initial Version(US - NGOMCT-343)
 * V1.0.1		    2025-11-20			    Charchit N.                   Updated(NGOMCT-1079)
 * V1.0.2       2025-12-29          Srinivas Shanigarapu          Updated(US - NGOMCT-235)
 */
public with sharing class AccountContactRelationService {
  
  private static String errorTagName;
  public static final String PATIENT = 'Patient';
  public static final String TRAINER = 'Trainer';
  // Track Contact IDs that have a primary trainer relationship to avoid SOQL in loops
  private static Set<Id> contactsWithPrimaryTrainerSet = new Set<Id>();
    
  /**
   * @description Sets the error tag name used to tag log entries generated by this service.
   * @param tag The tag name to apply to logger entries for error tracking.
   */
  public static void setErrorTagName(String tag) {
    errorTagName = tag;
  }
  /**
   * @description Holder for Account/Contact Ids and their pair keys used to deduplicate ACRs.
   */
  @TestVisible
  private class TrainerAccConData {
    Set<Id> accountIds = new Set<Id>();
    Set<Id> contactIds = new Set<Id>();
    Set<String> accConPairKeys = new Set<String>();
  }

  /**
   * @description Creates a unique key for Account-Contact pair for deduplication.
   * @param accountId Account ID
   * @param contactId Contact ID
   * @return String key in format "accountId::contactId"
   */
  private static String buildPairKey(Id accountId, Id contactId) {
    return String.valueOf(accountId) + '::' + String.valueOf(contactId);
  }

  /**
   * @description Logs DML errors for failed SaveResults.
   * @param results Database.SaveResult array from DML operation
   * @param records List of records that were attempted to insert/update
   * @param errorMessage Prefix for error message
   */
  @TestVisible
  private static void logDMLErrors(
    Database.SaveResult[] results,
    List<SObject> records,
    String errorMessage
  ) {
    for (Integer i = 0; i < results.size(); i++) {
      if (!results[i].isSuccess()) {
        for (Database.Error err : results[i].getErrors()) {
          Logger.error(errorMessage + err.getMessage(), results[i])
            .setRecord(records[i])
            .addTag(errorTagName);
        }
      }
    }
  }

  /**
   * @description Logs DML errors for failed SaveResults.
   * @param results Database.upsertResult array from DML operation
   * @param records List of records that were attempted to insert/update
   * @param errorMessage Prefix for error message
   */
  private static void logDMLErrors(
    Database.upsertResult[] results,
    List<SObject> records,
    String errorMessage
  ) {
    for (Integer i = 0; i < results.size(); i++) {
      if (!results[i].isSuccess()) {
        for (Database.Error err : results[i].getErrors()) {
          Logger.error(errorMessage + err.getMessage(), results[i])
            .setRecord(records[i])
            .addTag(errorTagName);
        }
      }
    }
  }

  /**
   * @description Creates an AccountContactRelation from pair key.
   * @param pairKey String in format "accountId::contactId"
   * @param personAccountName Whether to add Person account-specific fields
   * @return AccountContactRelation or null if invalid pair
   */
  @TestVisible
  private static AccountContactRelation createACRFromPairKey(
    String pairKey,
    String personAccountName
  ) {
    String[] parts = pairKey.split('::');
    if (parts.size() != 2) {
      return null;
    }

    AccountContactRelation newACR = new AccountContactRelation(
      AccountId = Id.valueOf(parts[0]),
      ContactId = Id.valueOf(parts[1])
    );

    if (personAccountName == PATIENT) {
      newACR.Roles = ConstantsUtil.ACR_ROLE_PATIENT_PRACTICE;
      newACR.IsActive = true;
      newACR.Is_Primary__c = true;
    } else if (personAccountName == TRAINER) {
      newACR.Roles = ConstantsUtil.ACR_ROLE_TRAINER;
      newACR.IsActive = true;
      newACR.Is_Primary__c = contactsWithPrimaryTrainerSet.contains(Id.valueOf(parts[1])) ? false : true;
    }
    return newACR;
  }

  /**
   * @description Builds TrainerAccConData from lead mappings.
   * @param leads List of leads to process
   * @param hpfToPracticeMap Map of HPF to Practice Account
   * @param accountToContactMap Map of Account to Contact
   * @return TrainerAccConData with populated pairs
   */
  private static TrainerAccConData buildAccConDataFromMappings(
    List<Lead> leads,
    Map<Id, Id> hpfToPracticeMap,
    Map<Id, Id> accountToContactMap
  ) {
    TrainerAccConData data = new TrainerAccConData();
    for (Lead l : leads) {
      Id practiceId = hpfToPracticeMap.get(l.Provider_Practice_Affiliation__c);
      Id contactId = accountToContactMap.get(l.ConvertedAccountId);

      if (practiceId != null && contactId != null) {
        data.accountIds.add(practiceId);
        data.contactIds.add(contactId);
        data.accConPairKeys.add(buildPairKey(practiceId, contactId));
      }
    }
    return data;
  }

  /**
   * @description Helper to pre-calculate Trainer ACR counts for a set of Contact IDs.
   * @param contactIds Set of Contact IDs to query.
   */
  private static void prepareTrainerAcrCache(Set<Id> contactIds) {
   
      for (AccountContactRelation acr : [
        SELECT ContactId
        FROM AccountContactRelation
        WHERE
          ContactId IN :contactIds
          AND Roles = :ConstantsUtil.ACR_ROLE_TRAINER
        WITH SYSTEM_MODE
      ]) {
        contactsWithPrimaryTrainerSet.add(acr.ContactId);
      }
  }

  /**
   * @description Extracts Account IDs from ACR list.
   * @param acrList List of AccountContactRelation records
   * @return Set of Account IDs
   */
  private static Set<Id> extractContactIds(
    List<AccountContactRelation> acrList
  ) {
    Set<Id> contactIds = new Set<Id>();
    for (AccountContactRelation acr : acrList) {
      contactIds.add(acr.ContactId);
    }
    return contactIds;
  }

  /**
   * @description Build unique AccountContactRelation records to create for the provided converted Leads.
   * @param trainerConvertedLeads Converted leads with Practice__c and ConvertedContactId populated.
   * @return List of AccountContactRelation to insert (may be empty).
   */
  @TestVisible
  private static List<AccountContactRelation> setupTrainerPracticeAccConRelations(
    List<Lead> trainerConvertedLeads
  ) {
    if (trainerConvertedLeads == null || trainerConvertedLeads.isEmpty()) {
      return new List<AccountContactRelation>();
    }
    TrainerAccConData trainerAccCon = new TrainerAccConData();
    for (Lead l : trainerConvertedLeads) {
      if (l.Practice__c != null && l.ConvertedContactId != null) {
        trainerAccCon.accountIds.add(l.Practice__c);
        trainerAccCon.contactIds.add(l.ConvertedContactId);
        trainerAccCon.accConPairKeys.add(
          buildPairKey(l.Practice__c, l.ConvertedContactId)
        );
      }
    }
    return buildAcrsToUpsert(trainerAccCon, TRAINER);
  }
  /**
   * @description From the deduped keys, exclude existing ACRs and prepare inserts.
   * @param trainerAccCon Aggregated Account/Contact data and pair keys.
   * @param personAccountName Whether to create Person account-specific ACRs with additional fields.
   * @return AccountContactRelation records to insert (may be empty).
   */
  @TestVisible
  private static List<AccountContactRelation> buildAcrsToUpsert(
    TrainerAccConData trainerAccCon,
    String personAccountName
  ) {
    List<AccountContactRelation> toCreateACRList = new List<AccountContactRelation>();
    Set<String> existingACRSet = new Set<String>();
    if (trainerAccCon.accConPairKeys.isEmpty()) {
      return new List<AccountContactRelation>();
    }

    // Prepare cache for Trainer counts before entering the loop
    if (personAccountName == TRAINER) {
      prepareTrainerAcrCache(trainerAccCon.contactIds);
    }

    list<AccountContactRelation> existingACRList = [
      SELECT Id, AccountId, ContactId
      FROM AccountContactRelation
      WHERE
        AccountId IN :trainerAccCon.accountIds
        AND ContactId IN :trainerAccCon.contactIds
      WITH SYSTEM_MODE
    ];

    if (!existingACRList.isEmpty()) {
      for (AccountContactRelation acr : existingACRList) {
        if (
          trainerAccCon.accConPairKeys.contains(
            buildPairKey(acr.AccountId, acr.ContactId)
          ) && personAccountName != TRAINER
        ) {
          trainerAccCon.accConPairKeys.remove(
            buildPairKey(acr.AccountId, acr.ContactId)
          );
          acr.Is_Primary__c = true;
          toCreateACRList.add(acr);
        }
        existingACRSet.add(buildPairKey(acr.AccountId, acr.ContactId));
      }
    }

    for (String accConPair : trainerAccCon.accConPairKeys) {
      if (!existingACRSet.contains(accConPair)) {
        AccountContactRelation newACR = createACRFromPairKey(
          accConPair,
          personAccountName
        );
        if (newACR != null) {
          toCreateACRList.add(newACR);
        }
      }
    }
    return toCreateACRList;
  }
  /**
   * @description Performs partial Upsert of AccountContactRelation records and logs any failures with the error tag.
   * @param acrRecords ACRs to Upsert.
   */
  @TestVisible
  private static void insertAccountContactRelationships(
    List<AccountContactRelation> acrRecords
  ) {
    if (acrRecords.isEmpty()) {
      return;
    }
    try {
      Database.upsertResult[] results = Database.Upsert(acrRecords, false);
      logDMLErrors(
        results,
        acrRecords,
        'Failed to Upsert AccountContactRelation record: '
      );

      if (Test.isRunningTest() && ConstantsUtil.customExceptionSwitch) {
        throw new MyCustomException('customExceptionSwitch is turned on');
      }
    } catch (Exception e) {
      Logger.error(
          'DML exception while Upserting AccountContactRelation records: ' +
          e.getMessage()
        )
        .addTag(errorTagName);
    }
  }
  /**
   * @description Creates AccountContactRelation records between Practice accounts and converted Contacts
   * for the provided list of Leads. Validates inputs, avoids duplicates, and performs partial DML insert
   * while logging failures with an error tag.
   * @param convertedPracticeLeads List of converted Lead records to evaluate.
   * @param tagName tag name for stream.
   */
  public static void createACRForTrainerPractice(
    List<Lead> convertedPracticeLeads,
    String tagName
  ) {
    if (convertedPracticeLeads == null || convertedPracticeLeads.isEmpty()) {
      return;
    }
    setErrorTagName(tagName);
    List<AccountContactRelation> toCreateACRList = setupTrainerPracticeAccConRelations(
      convertedPracticeLeads
    );
    insertAccountContactRelationships(toCreateACRList);
  }

  /**
   * @description Creates AccountContactRelation records for converted Patient leads with Practice affiliation.
   * Sets Is_Primary__c=true for new ACRs and updates existing primaries to false.
   * @param convertedPatientLeads List of converted Patient Lead records.
   * @param tagName Tag name for logger stream.
   */
  public static void createACRForPatientPractice(
    List<Lead> convertedPatientLeads,
    String tagName
  ) {
    if (convertedPatientLeads == null || convertedPatientLeads.isEmpty()) {
      return;
    }
    setErrorTagName(tagName);
    List<AccountContactRelation> toCreateACRList = setupPatientPracticeAccConRelations(
      convertedPatientLeads
    );

    updateExistingPrimaries(toCreateACRList);
    insertAccountContactRelationships(toCreateACRList);
  }

  /**
   * @description Build unique AccountContactRelation records to create for converted Patient leads.
   * @param patientConvertedLeads Converted Patient leads with Provider_Practice_Affiliation__c and ConvertedAccountId populated.
   * @return List of AccountContactRelation to insert (may be empty).
   */
  @TestVisible
  private static List<AccountContactRelation> setupPatientPracticeAccConRelations(
    List<Lead> patientConvertedLeads
  ) {
    if (patientConvertedLeads == null || patientConvertedLeads.isEmpty()) {
      return new List<AccountContactRelation>();
    }
    // Collect IDs from leads
    Set<Id> hpfIds = new Set<Id>();
    Set<Id> accountIds = new Set<Id>();
    for (Lead l : patientConvertedLeads) {
      if (
        l.Provider_Practice_Affiliation__c != null &&
        l.ConvertedAccountId != null
      ) {
        hpfIds.add(l.Provider_Practice_Affiliation__c);
        accountIds.add(l.ConvertedAccountId);
      }
    }

    if (hpfIds.isEmpty()) {
      return new List<AccountContactRelation>();
    }

    // Query mappings and build pairs
    Map<Id, Id> hpfToPracticeMap = queryHPFToPractice(hpfIds);
    Map<Id, Id> accountToContactMap = queryPersonAccounts(accountIds);
    TrainerAccConData patientAccCon = buildAccConDataFromMappings(
      patientConvertedLeads,
      hpfToPracticeMap,
      accountToContactMap
    );

    return buildAcrsToUpsert(patientAccCon, PATIENT);
  }

  /**
   * @description Queries HealthcarePractitionerFacility to get Practice Account mappings.
   * @param hpfIds Set of HealthcarePractitionerFacility IDs.
   * @return Map of HealthcarePractitionerFacility Id to Practice Account Id.
   */
  @TestVisible
  private static Map<Id, Id> queryHPFToPractice(Set<Id> hpfIds) {
    Map<Id, Id> hpfToPracticeMap = new Map<Id, Id>();

    for (HealthcarePractitionerFacility hpf : [
      SELECT Id, AccountId
      FROM HealthcarePractitionerFacility
      WHERE Id IN :hpfIds AND AccountId != NULL
      WITH SYSTEM_MODE
    ]) {
      hpfToPracticeMap.put(hpf.Id, hpf.AccountId);
    }

    return hpfToPracticeMap;
  }

  /**
   * @description Queries PersonAccount to get Contact IDs.
   * @param accountIds Set of PersonAccount IDs.
   * @return Map of Account Id to Contact Id.
   */
  @TestVisible
  private static Map<Id, Id> queryPersonAccounts(Set<Id> accountIds) {
    Map<Id, Id> accountToContactMap = new Map<Id, Id>();

    for (Account acc : [
      SELECT Id, PersonContactId
      FROM Account
      WHERE
        Id IN :accountIds
        AND IsPersonAccount = TRUE
        AND PersonContactId != NULL
      WITH SYSTEM_MODE
    ]) {
      accountToContactMap.put(acc.Id, acc.PersonContactId);
    }

    return accountToContactMap;
  }

  /**
   * @description Updates existing Is_Primary__c records to false for Practice accounts before inserting new primary ACRs.
   * @param newACRs List of new AccountContactRelation records to be inserted.
   */
  @TestVisible
  private static void updateExistingPrimaries(
    List<AccountContactRelation> newACRs
  ) {
    if (newACRs.isEmpty()) {
      return;
    }

    Set<Id> personContactIds = extractContactIds(newACRs);
    List<AccountContactRelation> existingPrimaries = [
      SELECT Id
      FROM AccountContactRelation
      WHERE ContactId IN :personContactIds AND Is_Primary__c = TRUE
      WITH SYSTEM_MODE
    ];
    if (existingPrimaries.isEmpty()) {
        return;
    }
    for (AccountContactRelation acr : existingPrimaries) {
      acr.Is_Primary__c = false;
    }
    try {
      Database.SaveResult[] results = Database.update(existingPrimaries, false);
      logDMLErrors(
        results,
        existingPrimaries,
        'Failed to update Is_Primary__c: '
      );
    } catch (Exception e) {
      Logger.error('Exception updating Is_Primary__c: ' + e.getMessage())
        .addTag(errorTagName);
    }
  }

  /**
   * @description Exception class for AccountContactRelationService Service
   */
  public class MyCustomException extends Exception {
  }
}